# ─── Modo de operação do roteador ────────────────────────────────────
# offline | local_primeiro | hibrido | claude | inteligente
CASAIQ_MODO=inteligente

# Limiar de confiança para segunda opinião via Claude (0.0 a 1.0)
CASAIQ_LIMIAR_CONFIANCA=0.65

# ─── Modelos Ollama ──────────────────────────────────────────────────
# VISÃO  (recomendado: qwen3-vl:4b → ~3.3 GB, rápido em CPU)
#   Alternativas:
#     qwen3-vl:4b      — leve, bom em pt-BR, ~3.3 GB     (recomendado p/ CPU)
#     qwen2.5vl:7b     — mais preciso, ~6 GB, lento em CPU
#     llava:7b         — alternativa clássica
CASAIQ_VISION_MODEL=qwen3-vl:4b

# TEXTO  (chat e enriquecimento)
CASAIQ_TEXT_MODEL=llama3.2:3b

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_S=45

# ─── Claude API (OPCIONAL — ativa roteamento inteligente) ────────────
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Servidor ────────────────────────────────────────────────────────
CASAIQ_HOST=0.0.0.0
CASAIQ_PORT=8000

# ─── Vídeo ───────────────────────────────────────────────────────────
CASAIQ_VIDEO_FPS=0.5
CASAIQ_VIDEO_MAX_FRAMES=10
